# This file fully overrides the root .gitignore for `dart pub publish`
# (pub ignores a directory's .gitignore when a .pubignore sits beside it).
# It must therefore re-state every .gitignore exclusion that matters for
# the archive, or build artifacts flood back in. Patterns without a
# leading slash match at any depth, so `build/` also covers example/.

# --- Mirror of .gitignore (non-hidden artifacts; dotfiles are dropped
# --- automatically as hidden, but listed here for clarity). ---
.dart_tool/
build/
**/doc/api/
/pubspec.lock

# --- Example scaffolding ---
# The example's generated per-platform folders (Xcode, gradle, CMake,
# app icons) are not source and inflate the archive ~10x. Consumers
# regenerate them with `flutter create .` in example/, then `flutter run`,
# so the example stays runnable on all platforms.
example/android/
example/ios/
example/macos/
example/linux/
example/windows/
